# Пример переменных окружения для локальной разработки и деплоя.
# Сейчас проект не читает .env автоматически, но эти переменные
# полезны как договоренность по конфигурации.

SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SETTINGS_MODULE=skill_blog.settings
