# Пример переменных окружения для локальной разработки и деплоя.
# Локально проект запускается и без .env, но для CI/production
# рекомендуется задавать переменные явно.

DJANGO_SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SETTINGS_MODULE=skill_blog.settings
